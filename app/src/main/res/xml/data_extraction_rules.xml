<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude auth tokens — never back up to Google Cloud -->
        <exclude domain="sharedpref" path="auth_prefs.xml"/>
        <!-- Exclude the local cache DB (tokens not stored here, but better to be safe) -->
        <exclude domain="database" path="relax_db"/>
    </cloud-backup>
    <device-transfer>
        <!-- Exclude auth tokens on device-to-device transfers too -->
        <exclude domain="sharedpref" path="auth_prefs.xml"/>
        <exclude domain="database" path="relax_db"/>
    </device-transfer>
</data-extraction-rules>